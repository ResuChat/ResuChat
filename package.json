{
  "name": "resuchat",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "license": "AGPL-3.0-only",
  "description": "对话式简历审批工具 - Conversational Resume Review & Approval Tool",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev:server": "pnpm --filter @resuchat/server dev",
    "dev:worker": "pnpm --filter @resuchat/server worker",
    "dev:web": "pnpm --filter @resuchat/web dev",
    "build:shared": "pnpm --filter @resuchat/shared build",
    "build:server": "pnpm run build:shared && pnpm --filter @resuchat/server build",
    "build:web": "pnpm --filter @resuchat/web build",
    "build": "pnpm run build:shared && pnpm --filter @resuchat/server build && pnpm --filter @resuchat/web build",
    "lint": "eslint .",
    "lint:packages": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm --filter @resuchat/server test && pnpm --filter @resuchat/web test:run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r exec tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild",
      "onnxruntime-node",
      "sharp",
      "ws"
    ]
  }
}
