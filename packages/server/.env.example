# ==================== 服务基础 ====================
PORT=3000                          # 服务监听端口
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173  # CORS 允许的域名（逗号分隔）
BIND_ADDRESS=127.0.0.1             # 绑定地址
SHUTDOWN_TIMEOUT=10000             # 优雅关闭超时（毫秒）
BODY_LIMIT=10mb                    # 请求体大小限制
MAX_FILE_SIZE=10485760             # 上传文件大小限制（字节，默认 10MB）
LOG_LEVEL=info                     # 日志级别：debug / info / warn / error
LOG_FORMAT=pretty                  # 日志格式：pretty / json
LOG_TO_FILE=true                   # 是否写入日志文件
LOG_DIR=logs                       # 日志目录
LOG_FILE=app.log                   # 日志文件名
START_WORKER_IN_SERVER=false       # 是否在 server 进程中启动 worker（开发调试用）

# ==================== 数据库与认证 ====================
DATABASE_URL="postgresql://postgres@localhost:5432/resuchat"  # PostgreSQL 连接串
DB_POOL_MAX=10                    # 数据库连接池最大连接数
DB_POOL_IDLE=10000                # 数据库空闲连接保留时间（毫秒）
DB_POOL_TIMEOUT=5000              # 数据库连接超时（毫秒）
JWT_SECRET=replace-with-a-secure-random-string               # JWT 签名密钥（必填）
JWT_ACCESS_EXPIRY=1800             # Access token 过期时间（秒，默认 30 分钟）
JWT_REFRESH_EXPIRY=604800          # Refresh token 过期时间（秒，默认 7 天）
BCRYPT_SALT_ROUNDS=10              # 密码哈希盐值轮数

# ==================== LLM / AI ====================
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxx  # DeepSeek API 密钥（必填）
DEFAULT_MODEL=deepseek-v4-pro       # 主模型（结构化输出、修改建议等）
FAST_MODEL=deepseek-v4-flash        # 快速模型（分类、摘要等轻量任务）
FAST_MODEL_MAX_TOKENS=8192          # 快速模型最大 token 数
FAST_MODEL_TEMPERATURE=0.1          # 快速模型温度参数
LLM_RETRIES=3                       # LLM 调用重试次数
LLM_RETRY_FACTOR=2                  # 重试退避因子
LLM_RETRY_MIN_TIMEOUT=1000          # 重试最小超时（毫秒）
AI_MAX_STEPS=6                      # AI 工具调用最大步数
AI_STREAM_RETRIES=3                 # 流式调用重试次数
LLM_MARKDOWN_TIMEOUT=120000         # Markdown 生成超时（毫秒）
DOC_PARSE_TIMEOUT=120000            # 文档解析超时（毫秒）

# ==================== Embedding ====================
EMBED_MODEL=Xenova/bge-small-zh-v1.5   # HuggingFace embedding 模型名称
EMBED_CACHE_TTL=86400                   # Embedding 缓存 TTL（秒）
EMBED_MEM_CACHE_MAX=500                 # 内存缓存最大条目数
EMBED_REMOTE_HOST=https://hf-mirror.com # HuggingFace 镜像地址（国内推荐）

# ==================== 验证码 ====================
CAPTCHA_TTL=300                    # 图形验证码有效期（秒，默认 5 分钟）
EMAIL_CODE_TTL=300                 # 邮箱验证码有效期（秒）
EMAIL_SEND_TIMEOUT=3000            # 邮件发送超时（毫秒）
TOKEN_CLEANUP_INTERVAL=60000       # 过期 token 清理间隔（毫秒）

# ==================== SMTP 邮件 ====================
SMTP_HOST=smtp.qq.com              # SMTP 服务器地址
SMTP_PORT=587                      # SMTP 端口
SMTP_USER=example@qq.com           # SMTP 用户名
SMTP_PASS=replace-with-smtp-password  # SMTP 密码/授权码
SMTP_CONNECTION_TIMEOUT=15000      # SMTP 连接超时（毫秒）
SMTP_GREETING_TIMEOUT=15000        # SMTP 问候超时（毫秒）
SMTP_SOCKET_TIMEOUT=15000          # SMTP 套接字超时（毫秒）

# ==================== 文档管理 ====================
DOCUMENTS_DIR=uploads/documents/by_hash  # 文件存储目录
DOC_PARSE_MAX_CHARS=8000               # 文档解析最大字符数
MAX_FILE_VERSIONS=5                    # 文件最大版本数
SYSTEM_DOC_MIN_LENGTH=100              # 系统知识库文档最小有效长度

# ==================== 分页与请求 ====================
MAX_PAGE_SIZE=200                  # 分页最大条数
DEFAULT_PAGE_SIZE=20               # 分页默认条数
URL_FETCH_TIMEOUT=10000            # URL 抓取超时（毫秒）
URL_FETCH_MAX_SIZE=5242880         # URL 抓取最大大小（字节，默认 5MB）
UPLOAD_TIMEOUT=240000              # 上传超时（毫秒）
DOC_START_TIMEOUT=120000           # 文档创建会话超时（毫秒）

# ==================== 对话摘要 ====================
SUMMARY_TRIGGER_COUNT=60           # 触发摘要的消息数阈值
SUMMARY_BATCH_SIZE=40              # 每批摘要的消息数
SUMMARY_MAX_UNCOMPRESSED=5         # 保留未压缩摘要的最大数量

# ==================== 向量数据库 ====================
VECTOR_DB_PATH=../../../data/lancedb  # LanceDB 存储路径
VECTOR_SEARCH_K=3                      # 向量检索 Top-K
VECTOR_DB_TABLE=system_chunks          # LanceDB 表名

# ==================== PDF 导出 ====================
PDF_PAGE_WIDTH=595.28              # PDF 页面宽度（pt，A4 标准）
PDF_PAGE_HEIGHT=841.89             # PDF 页面高度（pt）
PDF_MARGIN_TOP=50                  # 上边距
PDF_MARGIN_RIGHT=40                # 右边距
PDF_MARGIN_BOTTOM=40               # 下边距
PDF_MARGIN_LEFT=40                 # 左边距

# ==================== 其他 ====================
MERGE_MAX_OVERLAP=200              # 文档合并最大重叠字符数
CLASSIFY_MAX_LENGTH=300            # 分类最大文本长度
TITLE_MAX_LENGTH=15                # 自动标题最大长度
TITLE_MAX_QUERY_LENGTH=200         # 标题生成最大查询长度
INTENT_CONTEXT_WINDOW=4            # 意图分类上下文窗口（最近消息数）
UPLOAD_PROGRESS_TTL=30000          # 上传进度缓存 TTL（毫秒）

# ==================== Redis ====================
# REDIS_URL 被应用 Redis、BullMQ 队列和 worker 共享；Host/port 作为回退
USE_REDIS=true                          # 是否启用 Redis
REDIS_URL=redis://localhost:6379        # Redis 连接串
REDIS_HOST=localhost                    # Redis 主机（REDIS_URL 为空时使用）
REDIS_PORT=6379                         # Redis 端口
REDIS_PASSWORD=                         # Redis 密码
