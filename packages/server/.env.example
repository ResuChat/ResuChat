PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BIND_ADDRESS=127.0.0.1
SHUTDOWN_TIMEOUT=10000
BODY_LIMIT=10mb
MAX_FILE_SIZE=10485760
LOG_LEVEL=info
LOG_FORMAT=pretty
LOG_TO_FILE=true
LOG_DIR=logs
LOG_FILE=app.log
START_WORKER_IN_SERVER=false

DATABASE_URL="postgresql://postgres@localhost:5432/resuchat"
JWT_SECRET=replace-with-a-secure-random-string
JWT_ACCESS_EXPIRY=1800
JWT_REFRESH_EXPIRY=604800
BCRYPT_SALT_ROUNDS=10

DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxx
DEFAULT_MODEL=deepseek-v4-pro
FAST_MODEL=deepseek-v4-flash
FAST_MODEL_MAX_TOKENS=8192
FAST_MODEL_TEMPERATURE=0.1
LLM_RETRIES=3
LLM_RETRY_FACTOR=2
LLM_RETRY_MIN_TIMEOUT=1000
AI_MAX_STEPS=6
AI_STREAM_RETRIES=3
LLM_MARKDOWN_TIMEOUT=120000
DOC_PARSE_TIMEOUT=120000
EMBED_MODEL=Xenova/bge-small-zh-v1.5
EMBED_CACHE_TTL=86400
EMBED_MEM_CACHE_MAX=500
EMBED_REMOTE_HOST=https://hf-mirror.com

CAPTCHA_TTL=300
EMAIL_CODE_TTL=300
EMAIL_SEND_TIMEOUT=3000
TOKEN_CLEANUP_INTERVAL=60000

SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=example@qq.com
SMTP_PASS=replace-with-smtp-password
SMTP_CONNECTION_TIMEOUT=15000
SMTP_GREETING_TIMEOUT=15000
SMTP_SOCKET_TIMEOUT=15000

DOCUMENTS_DIR=uploads/documents/by_hash
DOC_PARSE_MAX_CHARS=8000
MAX_FILE_VERSIONS=5
SYSTEM_DOC_MIN_LENGTH=100

MAX_PAGE_SIZE=200
DEFAULT_PAGE_SIZE=20
URL_FETCH_TIMEOUT=10000
URL_FETCH_MAX_SIZE=5242880
UPLOAD_TIMEOUT=240000
DOC_START_TIMEOUT=120000

SUMMARY_TRIGGER_COUNT=60
SUMMARY_BATCH_SIZE=40
SUMMARY_MAX_UNCOMPRESSED=5

VECTOR_DB_PATH=../../../data/lancedb
VECTOR_SEARCH_K=3
VECTOR_DB_TABLE=system_chunks

PDF_PAGE_WIDTH=595.28
PDF_PAGE_HEIGHT=841.89
PDF_MARGIN_TOP=50
PDF_MARGIN_RIGHT=40
PDF_MARGIN_BOTTOM=40
PDF_MARGIN_LEFT=40

MERGE_MAX_OVERLAP=200
CLASSIFY_MAX_LENGTH=300
TITLE_MAX_LENGTH=15
TITLE_MAX_QUERY_LENGTH=200
INTENT_CONTEXT_WINDOW=4
UPLOAD_PROGRESS_TTL=30000

# REDIS_URL is shared by app Redis, BullMQ queues, and workers. Host/port remain as fallback inputs.
USE_REDIS=true
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
