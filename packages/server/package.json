{
  "name": "@resuchat/server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc --noEmit && tsdown && node -e \"const fs=require('fs');fs.cpSync('fonts','dist/fonts',{recursive:true})\"",
    "start": "node dist/index.js",
    "db:push": "drizzle-kit push --config drizzle.config.ts && pnpm run db:views",
    "db:views": "vite-node --config vite.config.ts scripts/sync-drizzle-views.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "pnpm exec eslint src",
    "worker": "vite-node --config vite.config.ts src/workers/index.ts",
    "vector:check-system": "vite-node --config vite.config.ts scripts/rebuild-system-vectors.ts --check",
    "vector:rebuild-system": "vite-node --config vite.config.ts scripts/rebuild-system-vectors.ts"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0-only",
  "description": "ResuChat backend - Express + AI SDK + PostgreSQL + LanceDB RAG engine",
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.32",
    "@huggingface/transformers": "^4.2.0",
    "@lancedb/lancedb": "^0.27.2",
    "@langchain/core": "^1.1.46",
    "@langchain/deepseek": "^1.0.25",
    "@langchain/textsplitters": "^1.0.1",
    "@napi-rs/canvas": "^1.0.0",
    "@resuchat/shared": "workspace:*",
    "ai": "^6.0.168",
    "apache-arrow": "^18.1.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "mdast-util-to-string": "^4.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "pdf-parse": "^2.4.5",
    "pdfmake": "^0.3.8",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mdast": "^4.0.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfmake": "^0.3.3",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "globals": "^16.5.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3"
  }
}
