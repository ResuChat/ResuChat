{
  "name": "@resuchat/web",
  "private": true,
  "version": "0.0.0",
  "license": "AGPL-3.0-only",
  "description": "ResuChat frontend - Vue 3 + Element Plus + AI SDK chat UI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:analyze": "vue-tsc --noEmit && vite build --mode analyze",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src",
    "lint:style": "stylelint src/**/*.css --fix",
    "format": "prettier --write src"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.10",
    "postcss-less": "^6.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "stylelint": "^17.9.0",
    "stylelint-config-recommended-less": "^4.2.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.4",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.8"
  },
  "dependencies": {
    "@ai-sdk/vue": "^3.0.168",
    "@resuchat/shared": "workspace:*",
    "@vueuse/core": "^14.3.0",
    "ai": "^6.0.168",
    "axios": "^1.15.2",
    "dayjs": "^1.11.21",
    "dompurify": "^3.4.8",
    "element-plus": "^2.13.7",
    "marked": "^18.0.4",
    "pdfjs-dist": "^6.0.227",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.33",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  }
}
