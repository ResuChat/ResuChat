{
  "name": "@resuchat/web",
  "private": true,
  "version": "0.0.0",
  "description": "ResuChat frontend - Vue 3 + Element Plus + AI SDK chat UI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .vue,.ts,.tsx",
    "lint:style": "stylelint src/**/*.{css,less,vue}",
    "format": "prettier --write src"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.8",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "vue-eslint-parser": "^10.4.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.10",
    "postcss-less": "^6.0.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.9.0",
    "stylelint-config-recommended-less": "^4.2.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.2.8"
  },
  "dependencies": {
    "@ai-sdk/vue": "^3.0.168",
    "ai": "^6.0.168",
    "axios": "^1.15.2",
    "element-plus": "^2.13.7",
    "marked": "^18.0.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  }
}
